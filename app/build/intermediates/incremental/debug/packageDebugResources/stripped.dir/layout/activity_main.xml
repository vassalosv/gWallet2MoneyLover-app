<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:theme="@style/ThemeOverlay.AppCompat.ActionBar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorPrimary"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══ Permissions card ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Required Permissions"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <!-- Row: Notification listener -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/label_notification_listener"
                            android:textSize="13sp"/>
                        <TextView android:id="@+id/tvStatusNotification"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="12sp" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btnGrantNotification"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="@string/btn_grant" android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Row: Accessibility -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/label_accessibility"
                            android:textSize="13sp"/>
                        <TextView android:id="@+id/tvStatusAccessibility"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="12sp" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btnGrantAccessibility"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="@string/btn_grant" android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Row: Overlay -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/label_overlay"
                            android:textSize="13sp"/>
                        <TextView android:id="@+id/tvStatusOverlay"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="12sp" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btnGrantOverlay"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="@string/btn_grant" android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Row: Battery optimization -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/label_battery"
                            android:textSize="13sp"/>
                        <TextView android:id="@+id/tvStatusBattery"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="12sp" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btnGrantBattery"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="@string/btn_grant" android:textSize="11sp"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ Version ══ -->
            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textSize="12sp"
                android:gravity="end"
                android:textColor="#888888" />

            <!-- ══ Test button ══ -->
            <Button
                android:id="@+id/btnTestPayment"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Simulate test payment (€12.40 at AB Vasilopoulos)" />

            <Button
                android:id="@+id/btnScanActiveNotifications"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Scan existing Wallet notifications" />

            <!-- ══ Debug log card ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notification log (last 20)"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <ScrollView
                        android:id="@+id/svDebugLog"
                        android:layout_width="match_parent"
                        android:layout_height="200dp">

                        <TextView
                            android:id="@+id/tvDebugLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textSize="11sp"
                            android:lineSpacingMultiplier="1.3"
                            android:text="(no wallet notifications received yet)" />
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
